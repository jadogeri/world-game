{
  "name": "world-game-app",
  "private": true,
  "scripts": {
    "api:dev": "pnpm --filter @repo/api run dev",
    "web:dev": "pnpm --filter @repo/web run dev",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "test": "pnpm run api:test && pnpm run web:test && pnpm run db:test",
    
    "dev": "doppler run -- turbo run dev", 
    
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "typecheck": "pnpm run typecheck:packages && pnpm -r --filter \"./apps/**\"  --if-present run typecheck",
    "typecheck:packages": "tsc --build",
    
    "db:test": "pnpm --filter @repo/db run db:test",
    "db:generate": "pnpm --filter @repo/db run db:generate",
    
    "db:push": "doppler run -- pnpm --filter @repo/db run db:push",
    "db:migrate": "doppler run -- pnpm --filter @repo/db run db:migrate",
    "db:studio": "doppler run -- pnpm --filter @repo/db run db:studio",
    "db:drop": "doppler run -- pnpm --filter @repo/db run db:drop",
    "db:clear": "doppler run -- pnpm --filter @repo/db run db:clear",
    
    "codegen": "pnpm --filter  @repo/api-spec run codegen",
    "api:test": "pnpm --filter @repo/api run test",
    "web:test": "pnpm --filter @repo/web run test",
    "api:test:coverage": "pnpm --filter @repo/api run test:coverage",
    "web:test:coverage": "pnpm --filter @repo/web run test:coverage",
    "db:test:coverage": "pnpm --filter @repo/db run test:coverage"
  },
  "devDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.62.2",
    "lightningcss-win32-x64-msvc": "^1.32.0",
    "prettier": "^3.7.4",
    "turbo": "^2.10.4",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@11.3.0",
  "engines": {
    "node": ">=18"
  }
}

