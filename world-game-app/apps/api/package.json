{
  "name": "@repo/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch src/index.ts",
    "build": "node ./build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
"typecheck": "tsc --build tsconfig.json",
    "test": "jest --config jest.config.cjs",
    "test:unit": "jest --config jest.config.cjs test/unit",
    "test:integration": "jest --config jest.config.cjs test/integration",
    "test:e2e": "jest --config jest.config.cjs test/e2e",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test:coverage": "jest --coverage"

  },
  "dependencies": {
    "@libsql/client": "^0.15.15",
    "@repo/api-zod": "workspace:*",
    "@repo/db": "workspace:*",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "catalog:",
    "express": "^5.2.1",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0"
  },
  "devDependencies": {
    "@swc/core": "^1.15.43",
    "@swc/jest": "^0.2.39",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "@types/supertest": "^6.0.3",
    "cross-env": "^10.1.0",
    "esbuild": "0.27.3",
    "esbuild-plugin-pino": "^2.3.3",
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "thread-stream": "3.1.0",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
