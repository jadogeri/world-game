{
  "buildCommand": "pnpm --filter=@repo/web build",
  "outputDirectory": "apps/web/dist/public",
  "installCommand": "pnpm install",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://onrender.com*"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
