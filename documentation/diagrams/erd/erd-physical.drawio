                <mxCell id="r_cat_def" value="DEFAULT (unixepoch(&#39;now&#39;) * 1000) ms" style="text;html=1;strokeColor=#6c8ebf;fillColor=#ffffff;align=left;verticalAlign=middle;spacingLeft=8;fontSize=11;" parent="scores_hdr" vertex="1">
